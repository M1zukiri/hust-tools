<Window x:Class="GalExtractor.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GalExtractor.UI.ViewModels"
        xmlns:conv="clr-namespace:GalExtractor.UI.Converters"
        mc:Ignorable="d"
        Title="GalExtractor - Visual Novel Resource Extractor" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:ImagePreviewConverter x:Key="ImagePreviewConverter"/>
        <conv:ImagePreviewVisibilityConverter x:Key="ImagePreviewVisibilityConverter"/>
        <conv:TextPreviewConverter x:Key="TextPreviewConverter"/>
        <conv:TextPreviewVisibilityConverter x:Key="TextPreviewVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0">
            <Button Content="Open File" Command="{Binding OpenFileCommand}" Padding="5"/>
            <Separator/>
            <Button Content="Extract All" Command="{Binding ExtractAllCommand}" Padding="5"/>
            <Button Content="Extract Selected" Command="{Binding ExtractSelectedCommand}" Padding="5"/>
            <Separator/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
        </ToolBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <DockPanel Grid.Column="0">
                <TextBlock Text="Files" DockPanel.Dock="Top" FontWeight="Bold" Margin="5"/>
                <ListView ItemsSource="{Binding FileEntries}" 
                          SelectedItem="{Binding SelectedEntry}"
                          IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                            <GridViewColumn Header="Size" DisplayMemberBinding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- Preview Area -->
            <DockPanel Grid.Column="2">
                <TextBlock Text="Preview" DockPanel.Dock="Top" FontWeight="Bold" Margin="5"/>
                <Border BorderBrush="Gray" BorderThickness="1" Margin="5">
                    <Grid>
                        <TextBlock Text="No preview available" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Image Preview -->
                        <Image Source="{Binding SelectedEntry, Converter={StaticResource ImagePreviewConverter}}"
                               Stretch="Uniform"
                               Visibility="{Binding SelectedEntry, Converter={StaticResource ImagePreviewVisibilityConverter}}"/>

                        <!-- Text Preview -->
                        <ScrollViewer Visibility="{Binding SelectedEntry, Converter={StaticResource TextPreviewVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedEntry, Converter={StaticResource TextPreviewConverter}}"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </DockPanel>
        </Grid>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="2" 
                     Height="10" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     IsIndeterminate="True"/>

        <!-- Log Console -->
        <DockPanel Grid.Row="3">
            <TextBlock Text="Log" DockPanel.Dock="Top" FontWeight="Bold" Margin="5"/>
            <TextBox Text="{Binding LogText, Mode=OneWay}" 
                     IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" 
                     FontFamily="Consolas"
                     Height="100"/>
        </DockPanel>
    </Grid>
</Window>
